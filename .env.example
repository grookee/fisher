# Database
POSTGRES_USER=fisher
POSTGRES_PASSWORD=fisher
POSTGRES_DB=fisher

# Backend
DATABASE_URL=postgres://fisher:fisher@db:5432/fisher?sslmode=disable
JWT_SECRET=change-this-to-a-secure-random-string-in-production
PORT=8080

# Spotify API (optional - get from https://developer.spotify.com)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/api/auth/spotify/callback

# Apple Music API (optional - get from https://developer.apple.com)
APPLE_MUSIC_DEVELOPER_TOKEN=

# Last.fm API (optional - get from https://www.last.fm/api/account/create)
LASTFM_API_KEY=

# Frontend
PUBLIC_API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
